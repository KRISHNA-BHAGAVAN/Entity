SUPABASE_URL=
SUPABASE_KEY=
BUCKET_NAME=
BYOK_MASTER_KEY=
GOOGLE_CLIENT_ID="your-client-id-from-google.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret-from-google"
GOOGLE_PICKER_API_KEY=your_new_api_key_here

# LangSmith Tracing Configuration
# Set to "true" to enable tracing for agent debugging and observability
LANGSMITH_TRACING=true
# Your LangSmith API key (starts with lsv2_...)
LANGSMITH_API_KEY=lsv2_your_api_key_here
# Optional: Project name for organizing traces (defaults to "default" if not set)
LANGSMITH_PROJECT=smart-documentation-system
